# ============================================
# Server Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Server Configuration
# ============================================
# Port number for the Express server
PORT=3000

# Environment mode: development | production
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string
# Local MongoDB: mongodb://localhost:27017/your-app-name
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_URI=mongodb://localhost:27017/your-app-name

# ============================================
# CORS Configuration
# ============================================
# Frontend URL for CORS (allowed origins)
# Development: http://localhost:5173
# Production: https://your-production-domain.com
CLIENT_URL=http://localhost:5173

# ============================================
# Auth0 Configuration
# ============================================
# Your Auth0 tenant domain (without https://)
# Example: dev-abc123.us.auth0.com
AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 API Audience (API Identifier)
# This must match the identifier you set when creating your Auth0 API
# Example: https://your-api-identifier
AUTH0_AUDIENCE=https://your-api-identifier

# ============================================
# Google Forms integration (direct Google OAuth2)
# ============================================
# The admin links their own Google account via /api/google/oauth/start. The
# server stores the resulting refresh token on the admin's User document and
# uses it to read Google Forms + Drive. Auth0 is NOT involved in Google access.
#
# Google Cloud Console setup (console.cloud.google.com):
#   1. Create an OAuth 2.0 Client ID (type: Web application).
#   2. Authorized redirect URI: must equal GOOGLE_OAUTH_REDIRECT_URI below.
#   3. APIs & Services > Library: enable "Google Forms API" and
#      "Google Drive API" in this same project.
#   4. OAuth consent screen: add scopes forms.body.readonly,
#      forms.responses.readonly, drive.readonly. While the app is in "Testing",
#      add the admin (lironefit@gmail.com) as a Test user.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# Random secret used to sign the OAuth `state` (CSRF + user binding).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_OAUTH_STATE_SECRET=change-me-to-a-long-random-string
