{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/lint.js",
            "timeout": 30,
            "statusMessage": "Running ESLint..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/test.js",
            "timeout": 60,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(node -e \"console.log\\(process.env.MONGO_URI ? 'set, len='+process.env.MONGO_URI.length : 'NOT SET'\\)\")"
    ]
  }
}
